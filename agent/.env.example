# ─── Groq LLM API Key (required for agent / LLM calls) ───
GROQ_API_KEY=

# ─── PostgreSQL Connection ───
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=frammer_database
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=disable


# ─── MCP Server (optional overrides) ───
# MCP_SERVER_NAME=Frammer Analytics MCP Server
# MCP_TRANSPORT=streamable-http
# DATABASE_SCHEMA=public

# ─── MCP Query Limits (optional overrides) ───
# MCP_DEFAULT_QUERY_LIMIT=200
# MCP_MAX_QUERY_LIMIT=1000
# MCP_DEFAULT_PREVIEW_LIMIT=25
# MCP_MAX_PREVIEW_LIMIT=200
# MCP_DEFAULT_CHART_LIMIT=500
# MCP_MAX_CHART_LIMIT=2000
