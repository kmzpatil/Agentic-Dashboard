# =============================================================================
# FRAMMER MASTER ENV TEMPLATE
# Copy this file to `.env` for local development or to a deployment-specific
# env file on the Linux VM for demo/prod-like runs.
# =============================================================================

# -----------------------------------------------------------------------------
# APP / RUNTIME
# -----------------------------------------------------------------------------
APP_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:5173,http://localhost:4000
FEATURE_MCP_ENABLED=true
FEATURE_LABS_ENABLED=true

# -----------------------------------------------------------------------------
# DATABASE
# Backend, bootstrap scripts, simulator, assistant compatibility layer, and MCP
# all resolve from this shared DB configuration.
# For local Postgres launched by `database/local_postgres.py`, keep these aligned.
# -----------------------------------------------------------------------------
PGHOST=localhost
PGPORT=5433
PGUSER=postgres
PGDATABASE=frammer_database
PGPASSWORD=
PGSSLMODE=prefer

# Compatibility aliases for legacy agent and bootstrap helpers.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_DB=frammer_database
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=prefer

# Optional full URLs if you prefer DSN-based config.
# DATABASE_URL=postgresql://postgres:@localhost:5433/frammer_database
# POSTGRES_URL=postgresql://postgres:@localhost:5433/frammer_database

# -----------------------------------------------------------------------------
# LOCAL POSTGRES CLUSTER
# Used by `database/local_postgres.py`.
# -----------------------------------------------------------------------------
LOCAL_POSTGRES_PORT=5433
LOCAL_POSTGRES_USER=postgres
LOCAL_POSTGRES_DB=frammer_database
# POSTGRES_BIN_DIR=/usr/lib/postgresql/16/bin

# -----------------------------------------------------------------------------
# AI / PROVIDER
# -----------------------------------------------------------------------------
AI_PROVIDER=azure-openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_DEPLOYMENT=o4-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Legacy compatibility key kept for one migration cycle only.
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# AUTH / JWT
# -----------------------------------------------------------------------------
JWT_SECRET=change-me
JWT_EXPIRES_IN=8h

# -----------------------------------------------------------------------------
# SEEDED CLIENT / DEMO BOOTSTRAP
# -----------------------------------------------------------------------------
AUTH_WEBSITE_ADMIN_USERNAME=website_admin
AUTH_WEBSITE_ADMIN_PASSWORD=Admin@12345

AUTH_CLIENT_ADMIN_USERNAME=client_admin_client1
AUTH_CLIENT_ADMIN_PASSWORD=Client@12345
AUTH_CLIENT_ADMIN_CLIENT_NAME=

AUTH_USER_USERNAME=user_local_1
AUTH_USER_PASSWORD=User@12345
AUTH_USER_ID=

# -----------------------------------------------------------------------------
# FRONTEND
# Only VITE_* variables are consumed by the web build.
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:4000/api

# -----------------------------------------------------------------------------
# MCP
# -----------------------------------------------------------------------------
MCP_SERVER_NAME=frammer-mcp
DATABASE_SCHEMA=public
