# =============================================================================
#  MASTER ENV TEMPLATE
#  Copy this file to .env and fill in your values.
#  This single file is loaded by: frontend/server.js, backend/server.py,
#  agent (agent.py / api_server.py / conversations.py), and the MCP server.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER
# Used by: backend/config/env.py, backend/server.py, frontend/server.js
# -----------------------------------------------------------------------------
PORT=4000
# API_PORT=4000   # fallback alias for PORT


# -----------------------------------------------------------------------------
# BACKEND POSTGRESQL  (PG* — used by the backend / frontend server)
# Used by: backend/config/env.py, backend/db/pool.py, frontend/server.js
# NOTE: backend connects to the *analytics* postgres (default port 5432)
# -----------------------------------------------------------------------------
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGDATABASE=frammer_db
PGPASSWORD=


# -----------------------------------------------------------------------------
# AGENT POSTGRESQL  (POSTGRES_* — used by the agent & MCP server)
# Used by: agent/agent.py, agent/mcp_server/config.py,
#          agent/tools/chart.py, agent/migrate_sqlite_to_postgres.py,
#          database/db_api.py, database/bootstrap_postgres.py
# NOTE: agent connects to a *separate* postgres instance (default port 5433)
#       Set POSTGRES_* vars OR provide a full POSTGRES_URL / DATABASE_URL.
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=frammer_database
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=disable

# Full connection URL (optional — overrides individual POSTGRES_* vars above)
# POSTGRES_URL=postgresql://user:password@localhost:5433/frammer_database
# DATABASE_URL=postgresql://user:password@localhost:5432/frammer_db


# -----------------------------------------------------------------------------
# LOCAL POSTGRES HELPER  (database/local_postgres.py)
# Only needed when using the embedded local postgres launcher.
# -----------------------------------------------------------------------------
# LOCAL_POSTGRES_PORT=5433
# LOCAL_POSTGRES_USER=
# LOCAL_POSTGRES_DB=frammer_database
# POSTGRES_BIN_DIR=   # path to postgres bin dir if not on PATH


# -----------------------------------------------------------------------------
# FRONTEND
# Used by: frontend/src/lib/constants.js (via Vite)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:4000/api


# -----------------------------------------------------------------------------
# BACKEND → AGENT PROXY
# Used by: backend/routes/agent_proxy.py
# -----------------------------------------------------------------------------
AGENT_BASE_URL=http://localhost:8000


# -----------------------------------------------------------------------------
# JWT / AUTH  (backend)
# Used by: backend/auth/jwt.py
# -----------------------------------------------------------------------------
JWT_SECRET=
JWT_EXPIRES_IN=8h
NODE_ENV=development


# -----------------------------------------------------------------------------
# LLM API KEYS
# Used by: agent/agent.py, agent/api_server.py (GROQ)
#          Orchestrator/Orchestration.py (GOOGLE)
# -----------------------------------------------------------------------------
GROQ_API_KEY=
GOOGLE_API_KEY=


# -----------------------------------------------------------------------------
# MCP SERVER SETTINGS  (agent/mcp_server/config.py)
# All optional — defaults shown as comments.
# -----------------------------------------------------------------------------
# MCP_SERVER_NAME=Frammer Analytics MCP Server
# MCP_TRANSPORT=streamable-http
# DATABASE_SCHEMA=public

# MCP_DEFAULT_QUERY_LIMIT=200
# MCP_MAX_QUERY_LIMIT=1000
# MCP_DEFAULT_PREVIEW_LIMIT=25
# MCP_MAX_PREVIEW_LIMIT=200
# MCP_DEFAULT_CHART_LIMIT=500
# MCP_MAX_CHART_LIMIT=2000


# -----------------------------------------------------------------------------
# AUTH SEED USERS  (backend/db/seed_auth_users.py)
# Used when seeding the auth database with initial users.
# The numbered variants (CLIENT_ADMIN1…4, USER1…4) are for the full seed;
# the un-numbered variants are generic fallbacks used by the script internals.
# -----------------------------------------------------------------------------

# Website admin
AUTH_WEBSITE_ADMIN_USERNAME=website_admin
AUTH_WEBSITE_ADMIN_PASSWORD=Admin@12345

# Generic client-admin fallback (used internally by seed script)
AUTH_CLIENT_ADMIN_USERNAME=client_admin_client1
AUTH_CLIENT_ADMIN_PASSWORD=
AUTH_CLIENT_ADMIN_CLIENT_NAME=

# Generic user fallback (used internally by seed script)
AUTH_USER_USERNAME=user_local_1
AUTH_USER_PASSWORD=
AUTH_USER_ID=

# Client admin accounts
AUTH_CLIENT_ADMIN1_USERNAME=client_admin_client1
AUTH_CLIENT_ADMIN1_PASSWORD=
AUTH_CLIENT_ADMIN1_CLIENT=Client 1

AUTH_CLIENT_ADMIN2_USERNAME=client_admin_client2
AUTH_CLIENT_ADMIN2_PASSWORD=
AUTH_CLIENT_ADMIN2_CLIENT=Client 2

AUTH_CLIENT_ADMIN3_USERNAME=client_admin_client3
AUTH_CLIENT_ADMIN3_PASSWORD=
AUTH_CLIENT_ADMIN3_CLIENT=Client 3

AUTH_CLIENT_ADMIN4_USERNAME=client_admin_client4
AUTH_CLIENT_ADMIN4_PASSWORD=
AUTH_CLIENT_ADMIN4_CLIENT=Client 4

# Named user accounts
AUTH_USER1_USERNAME=user_chandan
AUTH_USER1_PASSWORD=
AUTH_USER1_ID=1
AUTH_USER1_NAME=Chandan
AUTH_USER1_CLIENT=Client 1

AUTH_USER2_USERNAME=user_qa_purushottam
AUTH_USER2_PASSWORD=
AUTH_USER2_ID=2
AUTH_USER2_NAME=QA-Purushottam
AUTH_USER2_CLIENT=Client 2

AUTH_USER3_USERNAME=user_vikas_s
AUTH_USER3_PASSWORD=
AUTH_USER3_ID=3
AUTH_USER3_NAME=vikas.s@moolya.com
AUTH_USER3_CLIENT=Client 3

AUTH_USER4_USERNAME=user_sandeep_belaki
AUTH_USER4_PASSWORD=
AUTH_USER4_ID=4
AUTH_USER4_NAME=Sandeep Belaki
AUTH_USER4_CLIENT=Client 4
