# =============================================================================
# FRAMMER MASTER ENV TEMPLATE
# Copy this file to `.env` for local development or to a deployment-specific
# env file on the Linux VM for demo/prod-like runs.
# =============================================================================
GOOGLE_API_KEY=""
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_REPORT_MODEL=gemini-3-flash-preview
# -----------------------------------------------------------------------------
# APP / RUNTIME
# -----------------------------------------------------------------------------
APP_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:5173,http://localhost:4000
FEATURE_MCP_ENABLED=true
FEATURE_LABS_ENABLED=true

# -----------------------------------------------------------------------------
# DATABASE
# Backend, bootstrap scripts, assistant compatibility layer, and MCP
# resolve from this shared DB configuration.
# For local Postgres launched by `database/local_postgres.py`, keep these aligned.
# -----------------------------------------------------------------------------
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGDATABASE=frammer_database
PGPASSWORD=
PGSSLMODE=prefer

# Compatibility aliases for legacy agent and bootstrap helpers.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_DB=frammer_database
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=prefer

# Optional full URLs if you prefer DSN-based config.
# DATABASE_URL=postgresql://postgres:@127.0.0.1:55433/frammer_database
# POSTGRES_URL=postgresql://postgres:@127.0.0.1:55433/frammer_database

# -----------------------------------------------------------------------------
# LOCAL POSTGRES CLUSTER
# Used by `database/local_postgres.py`.
# -----------------------------------------------------------------------------
LOCAL_POSTGRES_HOST=127.0.0.1
LOCAL_POSTGRES_PORT=5432
LOCAL_POSTGRES_USER=postgres
LOCAL_POSTGRES_DB=frammer_database
# POSTGRES_BIN_DIR=/usr/lib/postgresql/16/bin

# -----------------------------------------------------------------------------
# SIMULATOR DATABASE
# Labs simulator uses a separate database so it cannot mutate KPI analytics.
# By default it reuses the same host/socket/user/password but a different DB.
# -----------------------------------------------------------------------------
SIMULATOR_PGHOST=127.0.0.1
SIMULATOR_PGPORT=5432
SIMULATOR_PGUSER=postgres
SIMULATOR_PGDATABASE=frammer_database
SIMULATOR_PGPASSWORD=
# SIMULATOR_MAINTENANCE_DB=postgres

# -----------------------------------------------------------------------------
# AI / PROVIDER
# -----------------------------------------------------------------------------
# AI_PROVIDER=azure-openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_DEPLOYMENT=o4-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Legacy compatibility key kept for one migration cycle only.
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# AUTH / JWT
# -----------------------------------------------------------------------------
JWT_SECRET=change-me
JWT_EXPIRES_IN=8h

# -----------------------------------------------------------------------------
# SEEDED CLIENT / DEMO BOOTSTRAP
# -----------------------------------------------------------------------------
AUTH_WEBSITE_ADMIN_USERNAME=website_admin
AUTH_WEBSITE_ADMIN_PASSWORD=Admin@12345

AUTH_CLIENT_ADMIN1_USERNAME=client_admin_client1
AUTH_CLIENT_ADMIN1_PASSWORD=Client1Admin@12345
AUTH_CLIENT_ADMIN1_CLIENT=Client 1

AUTH_CLIENT_ADMIN2_USERNAME=client_admin_client2
AUTH_CLIENT_ADMIN2_PASSWORD=Client2Admin@12345
AUTH_CLIENT_ADMIN2_CLIENT=Client 2

AUTH_USER1_USERNAME=user_chandan
AUTH_USER1_PASSWORD=User1@12345
AUTH_USER1_ID=1
AUTH_USER1_CLIENT=Client 1

AUTH_USER2_USERNAME=user_qa_purushottam
AUTH_USER2_PASSWORD=User2@12345
AUTH_USER2_ID=2
AUTH_USER2_CLIENT=Client 2

# Legacy fallback variables are still supported if you only want one client admin
# and one scoped user.
# AUTH_CLIENT_ADMIN_USERNAME=client_admin_client1
# AUTH_CLIENT_ADMIN_PASSWORD=Client@12345
# AUTH_CLIENT_ADMIN_CLIENT_NAME=
# AUTH_USER_USERNAME=user_local_1
# AUTH_USER_PASSWORD=User@12345
# AUTH_USER_ID=

# -----------------------------------------------------------------------------
# FRONTEND
# Only VITE_* variables are consumed by the web build.
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:4000/api

# -----------------------------------------------------------------------------
# MCP
# -----------------------------------------------------------------------------
MCP_SERVER_NAME=frammer-mcp
DATABASE_SCHEMA=public
